# Copy this file to .env and fill in at least one key.
#
# GROQ_API_KEY (primary)
#   Free, no credit card required. Sign up at https://console.groq.com/keys
#   Free tier (as of 2026): every model, 30 requests/min, 14,400 requests/day.
#
# CEREBRAS_API_KEY (automatic fallback if Groq errors or times out)
#   Free tier, no credit card required. Sign up at https://cloud.cerebras.ai
#
# You only need ONE of these to run the demo. Set both to see the
# FallbackAdapter actually in play (you can simulate a Groq outage by
# temporarily setting GROQ_API_KEY to an invalid value).

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

CEREBRAS_API_KEY=
CEREBRAS_MODEL=gpt-oss-120b

# --- Optional: swap STT/TTS providers (Task 1.2) ---
# Leave both unset (or "mock") to use the default zero-setup text-I/O
# stubs. Set to try a real provider instead -- also requires:
#   pip install -r requirements-optional-providers.txt
#
# STT_PROVIDER=deepgram
# DEEPGRAM_API_KEY=       # free trial, no card: console.deepgram.com
#
# TTS_PROVIDER=cartesia
# CARTESIA_API_KEY=       # free trial, no card: play.cartesia.ai
