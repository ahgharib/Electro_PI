# Copy this file to .env and fill in your key(s).
# Only GOOGLE_API_KEY is required for the default configuration below.

# --- Providers: "gemini" or "openai" ---
EMBEDDING_PROVIDER=gemini
GENERATION_PROVIDER=gemini

# Optional fallback providers -- used automatically if the primary provider's
# calls keep failing (see src/application/reliability.py). Leave blank to
# disable fallback. Requires OPENAI_API_KEY to be set if enabled.
FALLBACK_EMBEDDING_PROVIDER=
FALLBACK_GENERATION_PROVIDER=

# --- API keys ---
GOOGLE_API_KEY=your-gemini-api-key-here
OPENAI_API_KEY=

# --- Model names (override if a provider renames/deprecates a model) ---
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Chunking ---
CHUNK_SIZE_TOKENS=600
CHUNK_OVERLAP_TOKENS=80

# --- Ingestion / embedding quota management ---
# Gemini's free-tier embedding quota is roughly 100 requests/minute and
# 1,000 requests/day (subject to change -- check ai.google.dev). These
# settings help you stay under that, especially on larger document sets
# or across repeated `ingest.py` runs during development:
#   - SKIP_UNCHANGED_CHUNKS_ON_INGEST (default true): re-running ingest.py
#     will not re-embed chunks that are already indexed with unchanged
#     content. This is usually the single biggest quota saver -- most
#     quota exhaustion during development comes from repeatedly re-running
#     ingest on the same docs while testing, not from the docs themselves.
#   - EMBEDDING_BATCH_SIZE: how many chunks go into one embed_documents()
#     call (roughly one physical API request each).
#   - EMBEDDING_RPM_LIMIT: if set above 0, proactively paces embedding
#     calls to stay under this rate, instead of only reacting after a 429.
#     Set to e.g. 90 if you're on the free tier and ingesting a large corpus.
SKIP_UNCHANGED_CHUNKS_ON_INGEST=true
EMBEDDING_BATCH_SIZE=50
EMBEDDING_RPM_LIMIT=0

# --- Retrieval ---
RETRIEVAL_K=4
RELEVANCE_THRESHOLD=0.55
ENABLE_NEIGHBOR_EXPANSION=false

# --- Guardrails ---
QUESTION_TOKEN_LIMIT=300
CONTEXT_TOKEN_BUDGET=6000

# --- Vector store ---
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=rag_docs

# --- Reliability ---
RETRY_MAX_ATTEMPTS=2
RETRY_BACKOFF_SECONDS=1.0
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
CIRCUIT_BREAKER_RESET_SECONDS=30.0

# --- Monitoring ---
LOG_DIR=./logs
VERBOSE_CONSOLE=true

# Full per-chunk retrieval detail (scores, previews, threshold pass/fail)
# for every query, in addition to the partial VERBOSE_CONSOLE line above.
# Usually left off and toggled per-call instead via `--debug` on ask.py /
# eval.py, or pipeline.answer(question, debug=True).
DEBUG_RETRIEVAL=false

# --- Documents ---
DOCS_DIR=./docs
